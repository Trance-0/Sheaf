generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Entity {
  id             String   @id @default(uuid())
  name           String
  type           String
  description    String?
  homepage       String?
  jobPortal      String?
  interestWeight Float    @default(1.0)

  // Static financial / size-factor fields. All optional — we don't require
  // every entity to fill them in, and the UI + node-size factor both
  // gracefully fall back when a field is null. Amounts are stored in USD.
  stockTicker   String?
  marketCapUsd  Float?
  employeeCount Int?
  freeCashFlow  Float?
  foundedYear   Int?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  aliases   EntityAlias[]
  events    EventEntity[]
  snapshots EntitySnapshot[]
  cards     CacheCard[]
}

model EntityAlias {
  id       String @id @default(uuid())
  entityId String
  alias    String
  entity   Entity @relation(fields: [entityId], references: [id])
}

model Event {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  description String?

  // Explicit discriminator: "news" (multi-entity relationship event) or
  // "job" (single-agency job posting). Replaces the 0.1.7 heuristic of
  // "event has >= 2 entities => news" and lets /api/graph filter directly.
  category String?

  entities  EventEntity[]
  articles  Article[]
  cards     CacheCard[]
  createdAt DateTime      @default(now())
}

model EventEntity {
  id       String @id @default(uuid())
  eventId  String
  entityId String

  impactScore5d Float?
  impactScore5w Float?
  impactScore5m Float?
  impactScore5y Float?

  event  Event  @relation(fields: [eventId], references: [id])
  entity Entity @relation(fields: [entityId], references: [id])

  @@unique([eventId, entityId])
}

model Article {
  id          String   @id @default(uuid())
  url         String   @unique
  title       String
  provider    String?
  publishedAt DateTime
  body        String?

  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id])
}

model EntitySnapshot {
  id         String   @id @default(uuid())
  entityId   String
  date       DateTime
  netWorth   Float?
  growth     Float?
  statusText String?
  entity     Entity   @relation(fields: [entityId], references: [id])
}

model CacheCard {
  id        String   @id @default(uuid())
  type      String
  entityId  String?
  eventId   String?
  content   String
  updatedAt DateTime @updatedAt

  entity Entity? @relation(fields: [entityId], references: [id])
  event  Event?  @relation(fields: [eventId], references: [id])
}
