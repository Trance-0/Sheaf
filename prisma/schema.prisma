generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Entity {
  id             String   @id @default(uuid())
  name           String
  type           String
  description    String?
  homepage       String?
  jobPortal      String?
  interestWeight Float    @default(1.0)

  // Static financial / size-factor fields. All optional — we don't require
  // every entity to fill them in, and the UI + node-size factor both
  // gracefully fall back when a field is null. Amounts are stored in USD.
  stockTicker   String?
  marketCapUsd  Float?
  employeeCount Int?
  freeCashFlow  Float?
  foundedYear   Int?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  aliases   EntityAlias[]
  events    EventEntity[]
  snapshots EntitySnapshot[]
  cards     CacheCard[]
}

model EntityAlias {
  id       String @id @default(uuid())
  entityId String
  alias    String
  entity   Entity @relation(fields: [entityId], references: [id])
}

model Event {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  description String?

  // Explicit discriminator: "news" (multi-entity relationship event) or
  // "job" (single-agency job posting). Replaces the 0.1.7 heuristic of
  // "event has >= 2 entities => news" and lets /api/graph filter directly.
  category String?

  entities  EventEntity[]
  articles  Article[]
  cards     CacheCard[]
  createdAt DateTime      @default(now())
}

model EventEntity {
  id       String @id @default(uuid())
  eventId  String
  entityId String

  impactScore5d Float?
  impactScore5w Float?
  impactScore5m Float?
  impactScore5y Float?

  event  Event  @relation(fields: [eventId], references: [id])
  entity Entity @relation(fields: [entityId], references: [id])

  @@unique([eventId, entityId])
}

model Article {
  id          String   @id @default(uuid())
  url         String   @unique
  title       String
  provider    String?
  publishedAt DateTime
  body        String?

  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id])
}

model EntitySnapshot {
  id         String   @id @default(uuid())
  entityId   String
  // Date stamp for the point-in-time financial snapshot. Backfill script
  // uses the first day of each month (UTC) so monthly series align cleanly.
  date       DateTime

  // Legacy 0.1.x fields — kept for backward compatibility with any
  // existing rows. New code should read the explicit financial columns
  // below instead.
  netWorth   Float?
  growth     Float?
  statusText String?

  // 0.1.13 time-series financial columns. All nullable so we can record
  // only what we know — e.g. stock price gives us marketCapUsd but not
  // employees, private companies give us employees but no marketCap, etc.
  marketCapUsd  Float?
  employeeCount Int?
  freeCashFlow  Float?

  // Provenance: where the data point came from. `sourceName` is a short
  // human label ("Yahoo Finance", "SEC 10-K", "TechCrunch"), `sourceUrl`
  // is a direct link to the underlying source so every point is
  // auditable. Required by the "keep the most credible one, with source
  // link for each data point" invariant (originally tracked in
  // docs/TODO.md, formerly docs/TASK.md).
  sourceName String?
  sourceUrl  String?

  entity Entity @relation(fields: [entityId], references: [id])

  // One snapshot per entity per day — upsert on this composite key so
  // re-runs of the backfill script are idempotent.
  @@unique([entityId, date])
}

model CacheCard {
  id        String   @id @default(uuid())
  type      String
  entityId  String?
  eventId   String?
  content   String
  updatedAt DateTime @updatedAt

  entity Entity? @relation(fields: [entityId], references: [id])
  event  Event?  @relation(fields: [eventId], references: [id])
}
